{
  "manifest_version": 3,
  "name": "Subway Surfers Pro Tips",
  "version": "1.0.0",
  "description": "Get instant Subway Surfers tips, tricks, and leaderboards while you play. Level up your game with expert strategies!",
  "permissions": ["activeTab", "scripting", "tabs"],
  "host_permissions": ["https://subsurfapps.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    },
    "default_title": "Subway Surfers Pro Tips"
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["images/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
